{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/gonul-ilhan/layout,_N_T_/gonul-ilhan/page,_N_T_/gonul-ilhan"}},"html":"<!DOCTYPE html><!--40c3ezrJoxnRc59FxsayP--><html lang=\"tr\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" as=\"image\" imageSrcSet=\"/_next/image?url=%2Fimages%2Fgonul-ilhan-portrait.png&amp;w=1080&amp;q=75 1x, /_next/image?url=%2Fimages%2Fgonul-ilhan-portrait.png&amp;w=1920&amp;q=75 2x\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f423a6f9af026266.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-1017649d66d1259f.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-4f84124391a7dac4.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-9423082e7fb2c5c6.js\" async=\"\"></script><script src=\"/_next/static/chunks/909-a5da60d248a1c133.js\" async=\"\"></script><script src=\"/_next/static/chunks/619-ba102abea3e3d0e4.js\" async=\"\"></script><script src=\"/_next/static/chunks/666-04158ec67f461126.js\" async=\"\"></script><script src=\"/_next/static/chunks/37-e4069ba1992d9373.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-73baaca0e29666d4.js\" async=\"\"></script><script src=\"/_next/static/chunks/656-4d616a1275c1446f.js\" async=\"\"></script><script src=\"/_next/static/chunks/356-1143d17a0ca27254.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/gonul-ilhan/page-f08c6e1248826d13.js\" async=\"\"></script><title>Gönül İlhan Hakkında | Gönül İlhan</title><meta name=\"description\" content=\"Gönül İlhan&#x27;ın numerolojiye yaklaşımı, danışmanlık dili ve kişisel farkındalık odaklı çalışma alanı.\"/><meta name=\"keywords\" content=\"Gönül İlhan,numeroloji,numeroloji eğitimi,numeroloji danışmanlığı,kişisel gelişim,online numeroloji\"/><meta name=\"robots\" content=\"index, follow\"/><meta property=\"og:title\" content=\"Gönül İlhan | Numeroloji Uzmanı\"/><meta property=\"og:description\" content=\"Sayıların sembolik dilini kişisel farkındalık ve içgörü için zarif bir rehbere dönüştüren danışmanlık ve eğitim deneyimleri.\"/><meta property=\"og:locale\" content=\"tr_TR\"/><meta property=\"og:image\" content=\"https://gonulilhan.com/images/og-gonul-ilhan.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Gönül İlhan Numeroloji Uzmanı\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Gönül İlhan | Numeroloji Uzmanı\"/><meta name=\"twitter:description\" content=\"Sayıların sembolik dilini kişisel farkındalık ve içgörü için zarif bir rehbere dönüştüren danışmanlık ve eğitim deneyimleri.\"/><meta name=\"twitter:image\" content=\"https://gonulilhan.com/images/og-gonul-ilhan.png\"/><meta name=\"twitter:image:width\" content=\"1200\"/><meta name=\"twitter:image:height\" content=\"630\"/><meta name=\"twitter:image:alt\" content=\"Gönül İlhan Numeroloji Uzmanı\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"min-h-screen antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 border-b border-border/70 bg-ivory/86 backdrop-blur-xl\"><div class=\"container flex h-16 items-center justify-between sm:h-20\"><a class=\"group flex min-w-0 items-center gap-2 sm:gap-3\" aria-label=\"Gönül İlhan ana sayfa\" href=\"/\"><span class=\"flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-gold/40 bg-card text-gold shadow-sm transition-transform group-hover:-translate-y-0.5 sm:h-11 sm:w-11\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon-star h-5 w-5\" aria-hidden=\"true\"><path d=\"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9\"></path><path d=\"M20 3v4\"></path><path d=\"M22 5h-4\"></path></svg></span><span class=\"min-w-0 leading-tight\"><span class=\"block truncate font-editorial text-lg text-navy sm:text-xl\">Gönül İlhan</span><span class=\"block truncate text-[0.68rem] uppercase tracking-[0.16em] text-muted-foreground sm:text-xs sm:tracking-[0.2em]\">Numeroloji</span></span></a><nav class=\"hidden items-center gap-1 lg:flex\" aria-label=\"Ana menü\"><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/\">Ana Sayfa</a><a aria-current=\"page\" class=\"rounded-full px-4 py-2 text-sm font-medium transition hover:bg-card hover:text-navy bg-card text-navy shadow-sm\" href=\"/gonul-ilhan\">Gönül İlhan</a><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/hizmetler\">Hizmetler</a><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/egitimler\">Eğitimler</a><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/yorumlar\">Yorumlar</a><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/yazilar\">Yazılar</a><a class=\"rounded-full px-4 py-2 text-sm font-medium text-muted-foreground transition hover:bg-card hover:text-navy\" href=\"/iletisim\">İletişim</a></nav><div class=\"hidden items-center gap-3 lg:flex\"><a class=\"inline-flex min-w-0 items-center justify-center gap-2 whitespace-normal rounded-full text-center text-sm font-medium leading-snug transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;&gt;svg]:shrink-0 bg-primary text-primary-foreground shadow-glow hover:-translate-y-0.5 hover:bg-navy/92 min-h-9 px-4 py-2\" href=\"/randevu\">Randevu Al</a></div><button type=\"button\" class=\"inline-flex h-11 w-11 items-center justify-center rounded-full border border-border bg-card text-navy lg:hidden\" aria-label=\"Menüyü aç\" aria-expanded=\"false\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu h-5 w-5\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main><section class=\"container grid gap-10 py-14 sm:gap-12 sm:py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-center\"><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"sacred-frame overflow-hidden rounded-[2rem] border border-white/80 bg-card p-3 shadow-soft\"><img alt=\"Gönül İlhan portre yer tutucusu\" width=\"880\" height=\"980\" decoding=\"async\" data-nimg=\"1\" class=\"aspect-[0.86] w-full rounded-[1.5rem] object-cover\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fimages%2Fgonul-ilhan-portrait.png&amp;w=1080&amp;q=75 1x, /_next/image?url=%2Fimages%2Fgonul-ilhan-portrait.png&amp;w=1920&amp;q=75 2x\" src=\"/_next/image?url=%2Fimages%2Fgonul-ilhan-portrait.png&amp;w=1920&amp;q=75\"/></div></div><div class=\"space-y-8\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"max-w-3xl space-y-4\"><span class=\"inline-flex max-w-full items-center whitespace-normal rounded-full border border-gold/30 bg-champagne/18 px-3 py-1 text-center text-xs font-medium leading-snug text-navy\">Gönül İlhan</span><h2 class=\"break-words font-editorial text-[2rem] leading-[1.1] text-navy sm:text-5xl sm:leading-[1.08]\">Numerolojiyi sakin, etik ve insan odaklı bir farkındalık alanı olarak sunar.</h2><p class=\"text-base leading-7 text-muted-foreground sm:text-lg sm:leading-8\">Gönül İlhan&#x27;ın yaklaşımı; kişiyi tek bir sayıya indirmek yerine, hayatındaki temaları daha bilinçli görmesine yardımcı olan bütüncül bir okuma alanı açar.</p></div><div class=\"rounded-[1.5rem] border border-gold/25 bg-gold-sheen p-5 sm:p-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-quote mb-4 h-7 w-7 text-gold\" aria-hidden=\"true\"><path d=\"M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z\"></path><path d=\"M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z\"></path></svg><p class=\"font-editorial text-xl leading-8 text-navy sm:text-2xl sm:leading-9\">“Sayılar kesin hükümler değil, kendimize daha dikkatli bakmamız için nazik işaretler sunar.”</p></div><div class=\"flex flex-col gap-3 sm:flex-row\"><a class=\"inline-flex min-w-0 items-center justify-center gap-2 whitespace-normal rounded-full text-center text-sm font-medium leading-snug transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;&gt;svg]:shrink-0 bg-primary text-primary-foreground shadow-glow hover:-translate-y-0.5 hover:bg-navy/92 min-h-11 px-6 py-2\" href=\"/randevu\">Randevu Al</a><a class=\"inline-flex min-w-0 items-center justify-center gap-2 whitespace-normal rounded-full text-center text-sm font-medium leading-snug transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;&gt;svg]:shrink-0 border border-border bg-card/70 text-foreground hover:-translate-y-0.5 hover:border-gold/50 hover:bg-card min-h-11 px-6 py-2\" href=\"/egitimler\">Eğitimleri İncele<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></section><section class=\"bg-white/34 py-14 sm:py-16\"><div class=\"container grid gap-5 md:grid-cols-3\"><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur h-full\"><div class=\"min-w-0 sm:p-6 sm:pt-0 p-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-star mb-5 h-7 w-7 text-gold\" aria-hidden=\"true\"><path d=\"M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z\"></path></svg><h2 class=\"font-editorial text-3xl text-navy\">Danışmanlık</h2><p class=\"mt-3 text-sm leading-7 text-muted-foreground\">Kişisel haritanı ve dönemsel temalarını sakin bir görüşmede keşfet.</p></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur h-full\"><div class=\"min-w-0 sm:p-6 sm:pt-0 p-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-book-open mb-5 h-7 w-7 text-gold\" aria-hidden=\"true\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg><h2 class=\"font-editorial text-3xl text-navy\">Eğitim</h2><p class=\"mt-3 text-sm leading-7 text-muted-foreground\">Numerolojinin temel ve ileri uygulamalarını zarif, etik bir dille öğren.</p></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur h-full\"><div class=\"min-w-0 sm:p-6 sm:pt-0 p-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-briefcase-business mb-5 h-7 w-7 text-gold\" aria-hidden=\"true\"><path d=\"M12 12h.01\"></path><path d=\"M16 6V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2\"></path><path d=\"M22 13a18.15 18.15 0 0 1-20 0\"></path><rect width=\"20\" height=\"14\" x=\"2\" y=\"6\" rx=\"2\"></rect></svg><h2 class=\"font-editorial text-3xl text-navy\">Atölye</h2><p class=\"mt-3 text-sm leading-7 text-muted-foreground\">Grup enerjisiyle kendi haritan üzerinde uygulamalı farkındalık çalış.</p></div></div></div></div></section><section class=\"container grid gap-10 py-14 sm:py-16 lg:grid-cols-[0.9fr_1.1fr]\"><div class=\"max-w-3xl space-y-4\"><span class=\"inline-flex max-w-full items-center whitespace-normal rounded-full border border-gold/30 bg-champagne/18 px-3 py-1 text-center text-xs font-medium leading-snug text-navy\">Yaklaşım</span><h2 class=\"break-words font-editorial text-[2rem] leading-[1.1] text-navy sm:text-5xl sm:leading-[1.08]\">Güvenli, sade ve abartısız bir spiritüel dil.</h2><p class=\"text-base leading-7 text-muted-foreground sm:text-lg sm:leading-8\">Her çalışma, kişinin özgür iradesine ve gerçek hayat koşullarına saygı duyan bir çerçevede ilerler.</p></div><div class=\"space-y-5\"><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur\"><div class=\"min-w-0 flex gap-4 p-5 sm:gap-5 sm:p-6\"><span class=\"mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-navy text-sm text-primary-foreground\">1</span><div><h2 class=\"text-lg font-semibold text-navy\">Kişisel farkındalık odağı</h2><p class=\"mt-2 text-sm leading-7 text-muted-foreground\">Gönül İlhan, numerolojiyi kişinin kendisiyle daha dürüst ve şefkatli bir ilişki kurmasına yardımcı olan sembolik bir dil olarak ele alır.</p></div></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur\"><div class=\"min-w-0 flex gap-4 p-5 sm:gap-5 sm:p-6\"><span class=\"mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-navy text-sm text-primary-foreground\">2</span><div><h2 class=\"text-lg font-semibold text-navy\">Eğitim ve danışmanlık dili</h2><p class=\"mt-2 text-sm leading-7 text-muted-foreground\">Seans ve eğitimlerinde karmaşık kavramları sadeleştirir; katılımcının kendi içgörüsünü güçlendirmeyi merkeze alır.</p></div></div></div></div><div class=\"\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur\"><div class=\"min-w-0 flex gap-4 p-5 sm:gap-5 sm:p-6\"><span class=\"mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-navy text-sm text-primary-foreground\">3</span><div><h2 class=\"text-lg font-semibold text-navy\">Güvenli iletişim alanı</h2><p class=\"mt-2 text-sm leading-7 text-muted-foreground\">Her çalışma, kesin yargılar yerine anlamaya, dinlemeye ve kişinin özgür iradesini desteklemeye odaklanır.</p></div></div></div></div></div></section><section class=\"container py-14 sm:py-16\"><div class=\"min-w-0 rounded-[1.5rem] border border-border/80 bg-card/82 text-card-foreground shadow-soft backdrop-blur overflow-hidden\"><div class=\"min-w-0 sm:p-6 sm:pt-0 grid gap-8 p-6 lg:grid-cols-2 lg:p-10\"><div><h2 class=\"break-words font-editorial text-[2rem] text-navy sm:text-4xl\">Bu alan kimler için?</h2><p class=\"mt-4 leading-8 text-muted-foreground\">Numerolojiye merak duyan, kendini tanımak ve hayatındaki döngülere daha bilinçli bakmak isteyen herkes için sade bir başlangıç alanı.</p></div><ul class=\"grid gap-3\"><li class=\"flex gap-3 text-sm leading-7 text-navy\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-1 h-5 w-5 shrink-0 text-gold\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Kendini daha derinden tanımak isteyenler</li><li class=\"flex gap-3 text-sm leading-7 text-navy\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-1 h-5 w-5 shrink-0 text-gold\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Yaşam döngülerini anlamlandırmak isteyenler</li><li class=\"flex gap-3 text-sm leading-7 text-navy\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-1 h-5 w-5 shrink-0 text-gold\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Numerolojiyi etik ve sade bir dille öğrenmek isteyenler</li><li class=\"flex gap-3 text-sm leading-7 text-navy\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check mt-1 h-5 w-5 shrink-0 text-gold\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg>Kişisel gelişim çalışmalarına yeni bir perspektif katmak isteyenler</li></ul></div></div></section><section class=\"container py-14 sm:py-16\"><div class=\"rounded-[1.5rem] border border-border bg-card/80 p-5 sm:p-6\"><h2 class=\"font-editorial text-2xl text-navy sm:text-3xl\">Önemli not</h2><ul class=\"mt-5 grid gap-3\"><li class=\"text-sm leading-7 text-muted-foreground\">Numeroloji içerikleri kişisel farkındalık, ilham ve kişisel düşünme süreçlerini desteklemek amacıyla sunulur.</li><li class=\"text-sm leading-7 text-muted-foreground\">Bu sitedeki bilgiler tıbbi, psikolojik, hukuki, finansal veya benzeri profesyonel danışmanlık yerine geçmez.</li><li class=\"text-sm leading-7 text-muted-foreground\">Danışmanlık ve eğitim içerikleri kesin sonuç, garanti, kader belirleme veya gelecek tahmini iddiası taşımaz.</li></ul></div></section><section class=\"container py-14 sm:py-16\" style=\"opacity:0;transform:translateY(18px)\"><div class=\"sacred-frame overflow-hidden rounded-[2rem] bg-navy-depth p-5 text-primary-foreground shadow-soft min-[390px]:p-6 sm:p-12 lg:p-14\"><div class=\"grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center\"><div class=\"max-w-2xl space-y-4\"><p class=\"text-xs uppercase tracking-[0.18em] text-champagne sm:text-sm sm:tracking-[0.24em]\">Nazik bir başlangıç</p><h2 class=\"break-words font-editorial text-[2rem] leading-tight sm:text-5xl\">Kendi yolculuğunu sayılarla keşfetmeye hazır mısın?</h2><p class=\"text-base leading-8 text-primary-foreground/76\">Bir seans, eğitim ya da atölye ile numerolojiyi hayatına sakin, etik ve ilham veren bir farkındalık alanı olarak davet edebilirsin.</p></div><div class=\"flex flex-col gap-3 sm:flex-row lg:flex-col\"><a class=\"inline-flex min-w-0 items-center justify-center gap-2 whitespace-normal rounded-full text-center font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;&gt;svg]:shrink-0 shadow-glow hover:-translate-y-0.5 min-h-12 px-7 py-3 text-base w-full bg-champagne text-navy hover:bg-linen sm:w-auto lg:w-full\" href=\"/randevu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-calendar-days h-4 w-4\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path><path d=\"M8 14h.01\"></path><path d=\"M12 14h.01\"></path><path d=\"M16 14h.01\"></path><path d=\"M8 18h.01\"></path><path d=\"M12 18h.01\"></path><path d=\"M16 18h.01\"></path></svg>Randevu Al</a><a class=\"inline-flex min-w-0 items-center justify-center gap-2 whitespace-normal rounded-full text-center font-medium transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;&gt;svg]:shrink-0 border hover:-translate-y-0.5 hover:border-gold/50 min-h-12 px-7 py-3 text-base w-full border-white/20 bg-white/8 text-primary-foreground hover:bg-white/14 sm:w-auto lg:w-full\" href=\"/egitimler\">Eğitimleri İncele<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></div></section><!--$--><!--/$--></main><footer class=\"border-t border-border/70 bg-navy text-primary-foreground\"><div class=\"container grid gap-9 py-12 sm:gap-10 sm:py-14 lg:grid-cols-[1.2fr_0.8fr_0.8fr]\"><div class=\"max-w-md space-y-5\"><div class=\"flex min-w-0 items-center gap-3\"><span class=\"flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-champagne/40 text-champagne\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon-star h-5 w-5\" aria-hidden=\"true\"><path d=\"M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9\"></path><path d=\"M20 3v4\"></path><path d=\"M22 5h-4\"></path></svg></span><div><p class=\"font-editorial text-2xl\">Gönül İlhan</p><p class=\"text-xs uppercase tracking-[0.18em] text-champagne/80 sm:tracking-[0.22em]\">Numeroloji Uzmanı</p></div></div><p class=\"text-sm leading-7 text-primary-foreground/76\">Sayıların sembolik dilini kişisel farkındalık, içgörü ve daha bilinçli seçimler için zarif bir rehbere dönüştüren danışmanlık ve eğitim alanı.</p><p class=\"rounded-2xl border border-champagne/20 bg-white/5 p-4 text-xs leading-6 text-primary-foreground/70\">Numeroloji içerikleri kişisel farkındalık ve ilham amaçlıdır; tıbbi, psikolojik, hukuki veya finansal danışmanlık yerine geçmez.</p></div><div><h2 class=\"mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-champagne\">Menü</h2><ul class=\"space-y-3 text-sm\"><li><a class=\"text-primary-foreground/76 transition hover:text-champagne\" href=\"/\">Ana Sayfa</a></li><li><a class=\"text-primary-foreground/76 transition hover:text-champagne\" href=\"/gonul-